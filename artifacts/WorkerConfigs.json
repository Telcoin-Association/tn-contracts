\"internalType\":\"uint16\",\"name\":\"workerId\",\"type\":\"uint16\"}],\"name\":\"getWorkerConfig\",\"outputs\":[{\"internalType\":\"uint8\",\"name\":\"strategy\",\"type\":\"uint8\"},{\"internalType\":\"uint64\",\"name\":\"value\",\"type\":\"uint64\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"numWorkers\",\"outputs\":[{\"internalType\":\"uint16\",\"name\":\"\",\"type\":\"uint16\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"owner\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"pendingOwner\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"renounceOwnership\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint16\",\"name\":\"numWorkers_\",\"type\":\"uint16\"}],\"name\":\"setNumWorkers\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint16\",\"name\":\"workerId\",\"type\":\"uint16\"},{\"internalType\":\"uint8\",\"name\":\"strategy\",\"type\":\"uint8\"},{\"internalType\":\"uint64\",\"name\":\"value\",\"type\":\"uint64\"}],\"name\":\"setWorkerConfig\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint16[]\",\"name\":\"workerIds\",\"type\":\"uint16[]\"},{\"internalType\":\"uint8[]\",\"name\":\"strategies\",\"type\":\"uint8[]\"},{\"internalType\":\"uint64[]\",\"name\":\"values\",\"type\":\"uint64[]\"}],\"name\":\"setWorkerConfigsBatch\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"newOwner\",\"type\":\"address\"}],\"name\":\"transferOwnership\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"details\":\"Protocol usage: at each epoch boundary the execution layer reads `numWorkers()` and iterates `getWorkerConfig(0 .. numWorkers-1)` to build the per-worker fee parameters for the upcoming epoch. The contract therefore acts as the on-chain source of truth for worker fee policy.\",\"errors\":{\"MissingWorkerConfig(uint256)\":[{\"params\":{\"workerId\":\"The worker missing a config.\"}}],\"OwnableInvalidOwner(address)\":[{\"details\":\"The owner is not a valid owner account. (eg. `address(0)`)\"}],\"OwnableUnauthorizedAccount(address)\":[{\"details\":\"The caller account is not authorized to perform an operation.\"}],\"ValueBelowMinGas(uint64)\":[{\"params\":{\"value\":\"The rejected value.\"}}]},\"events\":{\"NumWorkersUpdated(uint16,uint16)\":{\"params\":{\"newValue\":\"New worker count.\",\"oldValue\":\"Previous worker count.\"}},\"WorkerConfigUpdated(uint256,uint8,uint64)\":{\"params\":{\"strategy\":\"The raw strategy id.\",\"value\":\"The config value (must be >= MIN_GAS).\",\"workerId\":\"The worker identifier.\"}}},\"kind\":\"dev\",\"methods\":{\"acceptOwnership()\":{\"details\":\"The new owner accepts the ownership transfer.\"},\"constructor\":{\"details\":\"Reverts `LengthMismatch()` if array lengths differ.      Reverts `ValueBelowMinGas(value)` if any value < MIN_GAS.\",\"params\":{\"owner_\":\"The address that will own this contract.\",\"strategies\":\"Array of strategy ids, one per worker (index = workerId).\",\"values\":\"Array of config values, one per worker.\"}},\"getWorkerConfig(uint16)\":{\"details\":\"Returns `(0, 0)` for workers that have never been configured.\",\"params\":{\"workerId\":\"The worker identifier.\"},\"returns\":{\"strategy\":\"The raw strategy id.\",\"value\":\"The config value.\"}},\"owner()\":{\"details\":\"Returns the address of the current owner.\"},\"pendingOwner()\":{\"details\":\"Returns the address of the pending owner.\"},\"renounceOwnership()\":{\"details\":\"Leaves the contract without owner. It will not be possible to call `onlyOwner` functions. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby disabling any functionality that is only available to the owner.\"},\"setNumWorkers(uint16)\":{\"details\":\"Reverts with `MissingWorkerConfig(i)` if any worker `0 .. numWorkers_-1`      has a config with `value < MIN_GAS` (including unset entries whose value is 0).\",\"params\":{\"numWorkers_\":\"The new worker count.\"}},\"setWorkerConfig(uint16,uint8,uint64)\":{\"details\":\"Allows setting configs for any `workerId`, including those beyond the      current `numWorkers`. Coverage is validated when `setNumWorkers` is called.\",\"params\":{\"strategy\":\"The raw strategy id (stored without interpretation).\",\"value\":\"The config value (must be >= MIN_GAS).\",\"workerId\":\"The worker identifier.\"}},\"setWorkerConfigsBatch(uint16[],uint8[],uint64[])\":{\"details\":\"Reverts `LengthMismatch()` if array lengths differ.      Reverts `ValueBelowMinGas(value)` if any value < MIN_GAS.\",\"params\":{\"strategies\":\"Array of strategy ids, one per worker.\",\"values\":\"Array of config values, one per worker.\",\"workerIds\":\"Array of worker identifiers.\"}},\"transferOwnership(address)\":{\"details\":\"Starts the ownership transfer of the contract to a new account. Replaces the pending transfer if there is one. Can only be called by the current owner. Setting `newOwner` to the zero address is allowed; this can be used to cancel an initiated ownership transfer.\"}},\"title\":\"WorkerConfigs\",\"version\":1},\"userdoc\":{\"errors\":{\"LengthMismatch()\":[{\"notice\":\"Thrown when constructor array lengths do not match.\"}],\"MissingWorkerConfig(uint256)\":[{\"notice\":\"Thrown when `setNumWorkers` is called but worker `workerId` has no config set.\"}],\"NumWorkersBelowMinimum()\":[{\"notice\":\"Thrown when the number of workers is set to zero.\"}],\"NumWorkersUnchanged()\":[{\"notice\":\"Thrown when `setNumWorkers` is called with the current value.\"}],\"ValueBelowMinGas(uint64)\":[{\"notice\":\"Thrown when a config value is below `MIN_GAS`.\"}]},\"events\":{\"NumWorkersUpdated(uint16,uint16)\":{\"notice\":\"Emitted when the number of workers changes.\"},\"WorkerConfigUpdated(uint256,uint8,uint64)\":{\"notice\":\"Emitted when a worker's config is created or updated.\"}},\"kind\":\"user\",\"methods\":{\"MIN_GAS()\":{\"notice\":\"Absolute minimum gas value any worker config may hold (7 wei).\"},\"constructor\":{\"notice\":\"Deploy with initial configs for every worker.\"},\"getWorkerConfig(uint16)\":{\"notice\":\"Return the stored config for a worker.\"},\"numWorkers()\":{\"notice\":\"The number of workers (used by protocol at epoch boundaries).\"},\"setNumWorkers(uint16)\":{\"notice\":\"Set the number of workers.\"},\"setWorkerConfig(uint16,uint8,uint64)\":{\"notice\":\"Set or update the fee config for a specific worker.\"},\"setWorkerConfigsBatch(uint16[],uint8[],uint64[])\":{\"notice\":\"Set or update fee configs for multiple workers in a single call.\"}},\"notice\":\"Strategy-agnostic per-worker fee config store. The constructor atomically sets `numWorkers` and every worker's config, guaranteeing full coverage from deployment. After deployment the owner can update individual configs and resize the worker set (with coverage checks).\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/consensus/WorkerConfigs.sol\":\"WorkerConfigs\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"none\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":@openzeppelin/contracts-upgradeable/=lib/openzeppelin-contracts-upgradeable/contracts/\",\":@openzeppelin/contracts/=lib/openzeppelin-contracts-upgradeable/lib/openzeppelin-contracts/contracts/\",\":erc4626-tests/=lib/openzeppelin-contracts-upgradeable/lib/erc4626-tests/\",\":forge-std/=lib/forge-std/src/\",\":halmos-cheatcodes/=lib/openzeppelin-contracts-upgradeable/lib/halmos-cheatcodes/src/